{
  "name": "nova",
  "version": "0.90.0",
  "type": "module",
  "scripts": {
    "build": "(cd ./frontend && npm run build) && (cd ./api && npm run build)",
    "start": "concurrently \"npm run dev --workspace api\" \"npm run start --workspace frontend\"",
    "dev:frontend": "npm run start --workspace frontend",
    "dev:backend": "npm run dev --workspace api",
    "lint": "npm run lint --workspace api && npm run lint --workspace frontend",
    "clean": "rm -rf ./**/*dist && rm -rf node_modules && rm -rf ./**/node_modules"
  },
  "workspaces": [
    "api",
    "frontend"
  ],
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.0"
  },
  "overrides": {
    "body-parser": "^2.2.1",
    "js-yaml": "^4.1.1",
    "qs": "^6.14.2",
    "validator": "^13.15.22"
  },
  "dependencies": {
    "@revealjs/react": "^0.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.13.2",
    "reveal.js": "^6.0.0"
  }
}
