{
  "name": "nova-api",
  "version": "0.90.0",
  "description": "A simple Express API that fetches and filters authenticated user details and decodes JWT tokens.",
  "license": "Apache-2.0",
  "author": "NDTP",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cp -r src/data dist/src/",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/server.js",
    "test": "jest",
    "test:coverage": "jest --collect-coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "@turf/turf": "7.2.0",
    "express": "5.1.0",
    "fuse.js": "7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@types/cors": "^2.8.17",
    "@types/express": "5.0.3",
    "@types/jest": "30.0.0",
    "@types/node": "24.0.3",
    "@types/supertest": "6.0.3",
    "@types/swagger-jsdoc": "6.0.4",
    "@types/swagger-ui-express": "4.1.8",
    "eslint": "9.29.0",
    "globals": "16.2.0",
    "jest": "30.0.0",
    "supertest": "7.1.1",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "ts-jest": "29.4.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.1"
  }
}
